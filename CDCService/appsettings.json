{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "EnableIdempotence": true,
    "Acks": -1,
    "MessageTimeoutMs": 30000,
    "Retries": 3,
    "RetryBackoffMs": 100
  },
  "CdcService": {
    "ProcessingDelaySeconds": 1,
    "ErrorRetryDelaySeconds": 5,
    "InitialRetryDelaySeconds": 10,
    "BatchSize": 100,
    "MaxBatchSize": 1000
  },
  "PaymentDocClasses": [
    "IncomingPayment",
    "OutgoingPayment",
    "PaymentInternal"
  ]
}
